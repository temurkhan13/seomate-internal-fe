# SEOMATE environment variables. Copy to .env and fill in.
# Never commit .env — only .env.example is tracked.

# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=seomate
POSTGRES_PASSWORD=seomate_dev
POSTGRES_DB=seomate
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
DATABASE_URL=postgresql+psycopg://seomate:seomate_dev@localhost:5433/seomate

# ─── Auditor / API runtime ───────────────────────────────────────────────────
SEOMATE_LOG_LEVEL=INFO
SEOMATE_DATA_DIR=./auditor/data

# ─── DataForSEO (the primary external SEO API) ───────────────────────────────
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# ─── Google APIs (owner-granted, only required for the pilot site) ───────────
# Service-account JSON file paths (gitignored)
GSC_SERVICE_ACCOUNT_FILE=./credentials/gsc.json
GBP_SERVICE_ACCOUNT_FILE=./credentials/gbp.json
GBP_ACCOUNT_ID=

# Public Google APIs (just need an API key)
GOOGLE_KG_API_KEY=
GOOGLE_PSI_API_KEY=

# ─── LLM providers (used in H1c and beyond) ──────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ─── AI search engines (used in H1d and beyond) ──────────────────────────────
PERPLEXITY_API_KEY=

# ─── Off-page / entity ecosystem (H1d) ───────────────────────────────────────
NEWSAPI_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
LISTEN_NOTES_API_KEY=
YOUTUBE_API_KEY=

# ─── Web UI → API (consumed by Next.js, Server Components only) ─────────────
# Server-side env var (NOT exposed to browser). On Vercel, set this to the
# Render URL of the seomate-be service.
API_BASE_URL=http://localhost:8000

# Optional HTTP Basic auth in "user:password" format. Must match the
# BASIC_AUTH_USER:BASIC_AUTH_PASSWORD on seomate-be. Server-side only;
# never reaches the browser. Leave empty for local dev; SET on Vercel.
API_BASIC_AUTH=

# Legacy var name kept for reference. The code reads API_BASE_URL (no prefix).
# The NEXT_PUBLIC_ prefix would expose the URL to the browser, which is not
# needed since only Server Components fetch the API.
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
